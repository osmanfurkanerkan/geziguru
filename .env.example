# GeziGuru ortam değişkenleri
# Bu dosyayı `.env` olarak kopyalayıp kendi anahtarınızı girin:
#   cp .env.example .env

# Google AI Studio'dan ücretsiz alınır: https://aistudio.google.com/apikey
GEMINI_API_KEY=buraya_anahtarinizi_yapistirin

# ADK'nın Gemini'yi (Vertex değil) AI Studio anahtarıyla kullanması için:
GOOGLE_GENAI_USE_VERTEXAI=FALSE

# Kullanılacak model. Günlük istek limiti (RPD) en yüksek olan flash-lite tercih edilir.
# gemini-3.1-flash-lite: RPD 500 (geliştirme için ideal). Alternatif: gemini-2.5-flash-lite (RPD 20).
GEZIGURU_MODEL=gemini-3.1-flash-lite

# SQLite veritabanı yolu (varsayılan: app/data/geziguru.db)
GEZIGURU_DB=app/data/geziguru.db
